generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PurchasePlatform {
  XIANYU
}

enum PurchaseOrderStatus {
  PAID
  WAITING_SHIPMENT
  IN_TRANSIT
  PENDING_INSPECTION
  PARTIALLY_STOCKED
  STOCKED
  CANCELLED
}

enum AllocationStatus {
  UNALLOCATED
  DRAFT
  CONFIRMED
}

enum AttachmentType {
  PURCHASE_ORDER
  PURCHASE_ORDER_ITEM
  INSPECTION
}

enum LogisticsStatus {
  NOT_SHIPPED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  EXCEPTION
  STALLED
  RETURNING
  UNKNOWN
}

enum InspectionStatus {
  PENDING
  IN_PROGRESS
  PASSED
  PROBLEM
}

enum InspectionResult {
  PASS
  PROBLEM
}

enum LocationStatus {
  LOCAL
  DEWU_WAREHOUSE
  RETURNING
  SOLD
}

enum SaleMode {
  NONE
  DEWU_LIGHTNING
  DEWU_STANDARD
  NINETY_FIVE
  XIANYU
  OTHER
}

enum ItemStatus {
  PENDING_INSPECTION
  STOCKED
  PLATFORM_SHIPPED
  PLATFORM_RECEIVED
  PLATFORM_IN_WAREHOUSE
  PLATFORM_LISTED
  PLATFORM_REJECTED
  RETURNING
  RETURNED
  SOLD
  LISTED
  IN_BATCH
  SHIPPED_TO_WAREHOUSE
  WAREHOUSE_RECEIVED
  INBOUND_SUCCESS
  INBOUND_FAILED
  PENDING_SETTLEMENT
  SETTLED
  PROBLEM
}

enum ShipmentPlatform {
  DEWU
  NINETY_FIVE
  OTHER
}

enum ShipmentPurpose {
  DEWU_LIGHTNING_INBOUND
  DEWU_STANDARD_FULFILLMENT
  NINETY_FIVE_INBOUND
  OTHER
}

enum ShipmentBatchStatus {
  DRAFT
  SHIPPED
  PARTIALLY_RECEIVED
  RECEIVED
  PARTIALLY_IN_WAREHOUSE
  IN_WAREHOUSE
  PARTIALLY_LISTED
  LISTED
  PARTIALLY_REJECTED
  RETURNING
  COMPLETED
  CANCELLED
}

enum ShipmentLineStatus {
  DRAFT
  SHIPPED
  RECEIVED
  IN_WAREHOUSE
  LISTED
  REJECTED
  RETURNING
  RETURNED
  CANCELLED
  SOLD
}

model User {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrders  PurchaseOrder[]
  attachments     Attachment[]
  logisticsEvents LogisticsEvent[]
  inspections     Inspection[]
  inventoryItems     InventoryItem[]
  reminderStates     ReminderState[]
  inventoryActionLogs InventoryActionLog[]
  todoResolutions    TodoResolution[]
  shipmentBatches         PlatformShipmentBatch[]
  shipmentGroups          PlatformShipmentGroup[]
  shipmentLines           PlatformShipmentLine[]
  shipmentAttachments     PlatformShipmentAttachment[]
  shipmentActionLogs      PlatformShipmentActionLog[]

  @@map("users")
}

model PurchaseOrder {
  id                      String              @id @default(cuid())
  ownerId                 String
  orderNo                 String
  platform                PurchasePlatform    @default(XIANYU)
  status                  PurchaseOrderStatus @default(PAID)
  allocationStatus        AllocationStatus    @default(UNALLOCATED)
  allocationConfirmedAt   DateTime?
  paidAt                  DateTime
  totalAmount             Decimal             @db.Decimal(12, 2)
  shippingAmount          Decimal             @default(0) @db.Decimal(12, 2)
  carrierCode             String?
  trackingNo              String?
  shippedAt               DateTime?
  deliveredAt             DateTime?
  logisticsStatus           LogisticsStatus @default(NOT_SHIPPED)
  logisticsLastCheckedAt    DateTime?
  logisticsLastEventAt      DateTime?
  logisticsLastEventText    String?
  logisticsExceptionType    String?
  logisticsExceptionMessage String?
  notes                   String?
  sellerNickname          String?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  owner User                @relation(fields: [ownerId], references: [id])
  items PurchaseOrderItem[]
  logisticsEvents LogisticsEvent[]

  @@unique([ownerId, orderNo])
  @@index([ownerId, status])
  @@index([ownerId, allocationStatus])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id                 String   @id @default(cuid())
  purchaseOrderId    String
  name               String
  skuText            String?
  quantity           Int
  allocatedTotalCost Decimal? @db.Decimal(12, 2)
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  inspections   Inspection[]
  inventoryItems InventoryItem[]

  @@index([purchaseOrderId])
  @@map("purchase_order_items")
}

model Attachment {
  id         String         @id @default(cuid())
  ownerId    String
  entityType AttachmentType
  entityId   String
  fileName   String
  mimeType   String
  size       Int
  storageKey String
  createdAt  DateTime       @default(now())

  owner User @relation(fields: [ownerId], references: [id])

  @@index([entityType, entityId])
  @@map("attachments")
}

model LogisticsEvent {
  id              String          @id @default(cuid())
  ownerId         String
  purchaseOrderId String
  carrierCode     String
  trackingNo      String
  eventTime       DateTime
  eventText       String
  location        String?
  status          LogisticsStatus
  rawData         Json?
  createdAt       DateTime        @default(now())

  owner         User          @relation(fields: [ownerId], references: [id])
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([ownerId, status])
  @@index([purchaseOrderId, eventTime])
  @@map("logistics_events")
}

model Inspection {
  id                  String           @id @default(cuid())
  ownerId             String
  purchaseOrderItemId String
  sequence            Int
  status              InspectionStatus @default(PENDING)
  currentStep         Int              @default(1)
  hasBox              Boolean?
  capCondition        String?
  paintCondition      String?
  leakageCondition    String?
  isNew               Boolean?
  hasUsageTrace       Boolean?
  batchCode           String?
  expiryDate          DateTime?
  appearanceNotes     String?
  result              InspectionResult?
  notes               String?
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  owner             User              @relation(fields: [ownerId], references: [id])
  purchaseOrderItem PurchaseOrderItem @relation(fields: [purchaseOrderItemId], references: [id], onDelete: Cascade)
  inventoryItem     InventoryItem?

  @@unique([purchaseOrderItemId, sequence])
  @@index([ownerId, status])
  @@map("inspections")
}

model InventoryItem {
  id                  String         @id @default(cuid())
  ownerId             String
  purchaseOrderItemId String
  inspectionId        String         @unique
  inventoryCode       String
  name                String
  skuText             String?
  unitCost            Decimal        @db.Decimal(12, 2)
  expiryDate          DateTime?
  locationStatus      LocationStatus @default(LOCAL)
  storageLocation     String?
  saleMode            SaleMode       @default(NONE)
  itemStatus          ItemStatus
  stockedAt           DateTime
  outboundAt          DateTime?
  problemReason       String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  owner             User              @relation(fields: [ownerId], references: [id])
  purchaseOrderItem PurchaseOrderItem @relation(fields: [purchaseOrderItemId], references: [id], onDelete: Cascade)
  inspection       Inspection        @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  actionLogs       InventoryActionLog[]
  shipmentLines    PlatformShipmentLine[]

  @@unique([ownerId, inventoryCode])
  @@index([ownerId, itemStatus])
  @@index([ownerId, locationStatus, saleMode])
  @@map("inventory_items")
}

enum ReminderStatus {
  SNOOZED
  RESOLVED
}

model ReminderState {
  id           String         @id @default(cuid())
  ownerId      String
  todoType     String
  entityType   String
  entityId     String
  status       ReminderStatus
  reasonKey    String?
  snoozedUntil DateTime?
  resolvedAt   DateTime?
  note         String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  owner User @relation(fields: [ownerId], references: [id])

  @@unique([ownerId, todoType, entityType, entityId])
  @@index([ownerId, status, snoozedUntil])
  @@map("reminder_states")
}

model InventoryActionLog {
  id                 String   @id @default(cuid())
  ownerId            String
  inventoryItemId    String
  purchaseOrderId    String?
  todoType           String?
  reasonKey          String?
  actionType         String
  note               String?
  oldSaleMode        String?
  newSaleMode        String?
  oldItemStatus      String?
  newItemStatus      String?
  oldStorageLocation String?
  newStorageLocation String?
  oldExpiryDate      DateTime?
  newExpiryDate      DateTime?
  createdAt          DateTime @default(now())

  owner         User          @relation(fields: [ownerId], references: [id])
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@index([ownerId, inventoryItemId, createdAt(sort: Desc)])
  @@index([ownerId, purchaseOrderId])
  @@map("inventory_action_logs")
}

model TodoResolution {
  id         String   @id @default(cuid())
  ownerId    String
  todoType   String
  entityType String
  entityId   String
  reasonKey  String
  actionType String
  note       String?
  resolvedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  owner User @relation(fields: [ownerId], references: [id])

  @@unique([ownerId, todoType, reasonKey])
  @@index([ownerId, entityType, entityId])
  @@index([ownerId, resolvedAt])
  @@map("todo_resolutions")
}

model PlatformShipmentBatch {
  id                     String              @id @default(cuid())
  ownerId                String
  batchNo                String
  platform               ShipmentPlatform
  defaultPurpose         ShipmentPurpose
  status                 ShipmentBatchStatus @default(DRAFT)
  carrierCode            String?
  trackingNo             String?
  shippedAt              DateTime?
  receivedAt             DateTime?
  outboundShippingCost   Decimal?            @db.Decimal(12, 2)
  packagingCost          Decimal?            @db.Decimal(12, 2)
  otherShipmentCost      Decimal?            @db.Decimal(12, 2)
  returnShippingCost     Decimal?            @db.Decimal(12, 2)
  note                   String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  owner       User                      @relation(fields: [ownerId], references: [id])
  groups      PlatformShipmentGroup[]
  lines       PlatformShipmentLine[]
  attachments PlatformShipmentAttachment[]
  actionLogs  PlatformShipmentActionLog[]

  @@unique([ownerId, batchNo])
  @@index([ownerId, status])
  @@index([ownerId, platform])
  @@map("platform_shipment_batches")
}

model PlatformShipmentGroup {
  id               String            @id @default(cuid())
  ownerId          String
  batchId          String
  platformOrderNo  String?
  platformTradeNo  String?
  groupName        String?
  purpose          ShipmentPurpose?
  note             String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  owner  User                    @relation(fields: [ownerId], references: [id])
  batch  PlatformShipmentBatch   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  lines  PlatformShipmentLine[]

  @@index([ownerId, batchId])
  @@map("platform_shipment_groups")
}

model PlatformShipmentLine {
  id                         String              @id @default(cuid())
  ownerId                    String
  batchId                    String
  groupId                    String?
  inventoryItemId            String
  lineStatus                 ShipmentLineStatus  @default(DRAFT)
  inventoryCodeSnapshot      String
  productNameSnapshot        String
  skuSnapshot                String?
  unitCostSnapshot           Decimal             @db.Decimal(12, 2)
  oldSaleModeSnapshot        String?
  newSaleModeSnapshot        String?
  sourcePurchaseOrderId      String
  packedCheckedAt            DateTime?
  packedChecked              Boolean             @default(false)
  rejectedReason             String?
  returnCarrierCode          String?
  returnTrackingNo           String?
  returnedAt                 DateTime?
  returnedStorageLocation    String?
  note                       String?
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt

  owner         User                    @relation(fields: [ownerId], references: [id])
  batch         PlatformShipmentBatch   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  group         PlatformShipmentGroup?  @relation(fields: [groupId], references: [id], onDelete: SetNull)
  inventoryItem InventoryItem           @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@unique([ownerId, inventoryItemId, batchId])
  @@index([ownerId, batchId])
  @@index([ownerId, inventoryItemId])
  @@index([ownerId, lineStatus])
  @@map("platform_shipment_lines")
}

model PlatformShipmentAttachment {
  id         String   @id @default(cuid())
  ownerId    String
  batchId    String
  lineId     String?
  fileName   String
  fileUrl    String
  fileType   String
  note       String?
  createdAt  DateTime @default(now())

  owner User                    @relation(fields: [ownerId], references: [id])
  batch PlatformShipmentBatch   @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([ownerId, batchId])
  @@map("platform_shipment_attachments")
}

model PlatformShipmentActionLog {
  id              String   @id @default(cuid())
  ownerId         String
  batchId         String
  lineId          String?
  inventoryItemId String?
  actionType      String
  oldStatus       String?
  newStatus       String?
  oldItemStatus   String?
  newItemStatus   String?
  note            String?
  createdAt       DateTime @default(now())

  owner User                    @relation(fields: [ownerId], references: [id])
  batch PlatformShipmentBatch   @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([ownerId, batchId, createdAt(sort: Desc)])
  @@index([ownerId, inventoryItemId])
  @@map("platform_shipment_action_logs")
}
